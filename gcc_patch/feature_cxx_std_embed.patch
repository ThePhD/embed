+#define expand_if_necessary(ptr, size, idx, additional_size, small_buf) if (additional_size > size || idx >= (size - additional_size)) { char *new_ptr = XCNEWVEC (char, ((size * 2) + additional_size + 1)); memcpy (new_ptr, ptr, size * 2); if (ptr != small_buf) { free (ptr); } ptr = new_ptr; size *= 2; size += additional_size + 1; }
+#define expand_if_necessary_one(ptr, size, idx, small_buf) if (idx >= size) { char *new_ptr = XCNEWVEC (char, size * 2); memcpy(new_ptr, ptr, size * 2); if (ptr != small_buf) { free (ptr); } ptr = new_ptr; size *= 2; }
+#define dirty_push(ptr, size, idx, c) { ptr[idx] = c; ++idx;  }
+#define safe_push(ptr, size, idx, c, small_buf) { expand_if_necessary_one (ptr, size, idx, small_buf); dirty_push (ptr, size, idx, c);  }
+#define safe_append(ptr, size, idx, cfirst, csize, small_buf) { expand_if_necessary (ptr, size, idx, csize, small_buf); for(unsigned int i = 0; i < csize; ++i) { dirty_push (ptr, size, idx, cfirst[i]); } }
