+static global_constant_evaluation_link* gce_head = NULL;
+static global_constant_evaluation_link* gce_tail = NULL;
+
+void push_constant_eval_list(global_constant_evaluation_link *next)
+{
+  if (gce_head == NULL)
+    {
+      next->next = NULL;
+      next->prev = NULL;
+      gce_head = next;
+      gce_tail = next;
+      return;
+    }
+
+  if (next->value == gce_tail->value)
+    return;
+
+  next->prev = gce_tail;
+  gce_tail->next = next;
+  gce_tail = next;
+}
+
+void pop_constant_eval_list(global_constant_evaluation_link *verify)
+{
+  gcc_checking_assert (verify != NULL && gce_tail != NULL
+			? verify == gce_tail
+			: true);
+  if (gce_head == NULL)
+    return;
+  if (gce_head == gce_tail)
+    {
+      gce_head = NULL;
+      gce_tail = NULL;
+      return;
+    }
+  global_constant_evaluation_link *new_tail = gce_tail->prev;
+  new_tail->next = NULL;
+  gce_tail = new_tail;
+}
+
+const global_constant_evaluation_link *
+get_constant_eval_list_begin()
+{
+  return gce_head;
+}
+
+const global_constant_evaluation_link *
+get_constant_eval_list_end()
+{
+  return gce_tail;
+}
+
+const global_constant_evaluation_link *
+get_constant_eval_list_rev_at(int at)
+{
+  if (gce_head == NULL)
+    return NULL;
+
+  if (at < 0)
+    {
+      global_constant_evaluation_link *target = gce_head;
+      at = -at;
+      while (target->next != NULL && at-- > 0)
+	target = target->next;
+      return target;
+    }
+
+  global_constant_evaluation_link *target = gce_tail;
+  while (target->prev != NULL && at-- > 0)
+    target = target->prev;
+  return target;
+}
+
+const global_constant_evaluation_link *
+get_constant_eval_list_at(int at)
+{
+  if (gce_head == NULL)
+    return NULL;
+
+  if (at < 0)
+    {
+      global_constant_evaluation_link *target = gce_tail;
+      at = -at;
+      while (target->prev != NULL && at-- > 0)
+	target = target->prev;
+      return target;
+    }
+
+  global_constant_evaluation_link *target = gce_head;
+  while (target->next != NULL && at-- > 0)
+    target = target->next;
+  return target;
+}
