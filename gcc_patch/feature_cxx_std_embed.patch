+  /**
+   * @defgroup embed Binary data at compile-time
+   * @addtogroup embed
+   * @since C++29
+   * @{
+   */
+
+/// @cond undocumented
+namespace __embed
+{
+
+  enum __builtin_embed_status
+    {
+      __file_not_found = 0,
+      __file_found = 1,
+      __file_found_no_depends = 2,
+      __file_found_empty = 3,
+    };
+
+  inline constexpr unsigned int __quoted_search_distance = 0b101;
+
+#define _EMBED_FAIL(...) \
+  do { __glibcxx_assert(false && __VA_ARGS__); __builtin_abort(); } while(false)
+
+  // generic implementation to save on copy-paste nonsense
+  // and not come up with clever constraints for the `__resource`
+  // type.
+  template<typename _By, size_t _Ex, typename _Sv>
+    [[nodiscard]]
+    consteval span<const _By, _Ex>
+    __embed(const _Sv& __resource, size_t __offset,
+	    [[maybe_unused]] const optional<size_t>& __limit)
+    noexcept
+    {
+      int __status = -1;
+      _By const* __ptr = nullptr;
+      size_t __size = 0;
+      if constexpr (_Ex != dynamic_extent)
+	{
+	  __ptr = __builtin_std_embed(__quoted_search_distance, __status,
+				      __size, __ptr,
+				      __resource.size(), __resource.data(),
+				      __offset, _Ex);
+	}
+      else
+	{
+	  __ptr = __limit
+	    ? __builtin_std_embed(__quoted_search_distance, __status,
+				  __size, __ptr,
+				  __resource.size(), __resource.data(),
+				  __offset, *__limit)
+	    : __builtin_std_embed(__quoted_search_distance, __status,
+				  __size, __ptr,
+				  __resource.size(), __resource.data(),
+				  __offset);
+	}
+      if (__status == __file_not_found)
+	{
+	  _EMBED_FAIL("the file was not found");
+	}
+      if (__status == __file_found_no_depends)
+	{
+	  _EMBED_FAIL("file not covered by a '#depend' directive");
+	}
+      if constexpr (_Ex != dynamic_extent)
+	{
+	  if (_Ex > __size)
+	    {
+	      _EMBED_FAIL("extent is larger than the file's size");
+	    }
+	  __size = _Ex;
+	}
+      if (__status == __file_found_empty)
+	{
+	  return span<const _By, _Ex>();
+	}
+      return span<const _By, _Ex>(__ptr, __size);
+    }
+
+#undef _EMBED_FAIL
+
+}
+/// @endcond
+
+
+  /// @brief Embed a backing array of binary data of type `const _By`
+  /// @tparam _By Shall be one of `unsigned char`, `char`, or `std::byte`.
+  /// @param[in] __resource The name of the resource. The treatment of the
+  ///                       encoding of the string is unspecified
+  ///                       and subject to frontend builtins.
+  /// @param[in] __offset The number of `const T` elements to skip from the
+  ///                     resource. Applied before the limit.
+  /// @param[in] __limit The maximum number of `const T` elements to read,
